{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentIsOK",
  "version": "1.0.8",
  "identifier": "com.agentisok.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentIsOK",
        "width": 248,
        "height": 56,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true,
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGN0Q3OEE1QzVCODhBMkQKUldRdGlyakZwWGg5TDVyTC84a3Fmd0toQ044UlZDaWNpYVN2Wnp3ZVhRU1lnSzBTSjBNYlZYYzIK",
      "endpoints": [
        "https://github.com/JaikenWong/AgentIsOK/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/hooks-cleanup.nsh",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}

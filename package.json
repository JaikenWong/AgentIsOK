{
  "name": "thatisok",
  "version": "1.1.3",
  "description": "Local approval and usage cockpit for Claude Code, Codex, Gemini, Cursor, MiniMax, and DeepSeek",
  "main": "main/index.js",
  "bin": {
    "ok": "bin/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build": "electron-builder build",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "test:hook": "node bin/test-permission-hook.js codex",
    "test": "echo \"Error: no test specified\" && exit 1",
    "plugin:install": "node bin/install-opencode-plugin.js install",
    "plugin:uninstall": "node bin/install-opencode-plugin.js uninstall",
    "plugin:status": "node bin/install-opencode-plugin.js status"
  },
  "build": {
    "appId": "com.thatisok.app",
    "productName": "ThatIsOk",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ThatIsOk"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "bridge/**/*",
      "shared/**/*",
      "config/**/*",
      "assets/**/*",
      "plugins/**/*",
      "bin/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "bridge/**/*",
      "shared/ipc-config.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.3",
    "@electron/rebuild": "^4.0.4",
    "chokidar": "^5.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "electron-rebuild": "^3.2.9"
  }
}
